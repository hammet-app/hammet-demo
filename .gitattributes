# Auto detect text files and normalize to LF in the repo
* text=auto eol=lf

# Explicitly declare common text files
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Windows specific scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Treat these as binary - Git won't touch them
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.ttf binary
*.woff binary
*.woff2 binary
